# ---- App ----
# NextAuth secret (generate: openssl rand -base64 32)
AUTH_SECRET=change-me-generate-32-bytes
# Base URL (as seen from the browser, behind reverse proxy)
NEXTAUTH_URL=https://your-domain.example

# ---- Database ----
# Matches docker-compose service "db"
DATABASE_URL=postgresql://subs:change-me-strong-pw@localhost:5432/subs?schema=public

# ---- Encryption ----
# AES-256-GCM master key (32 bytes, base64). generate: openssl rand -base64 32
ENCRYPTION_KEY=change-me-32-bytes-base64

# ---- Owner seed (first deploy only) ----
SEED_OWNER_EMAIL=owner@example.com
# Argon2id hash of the owner password. Generate locally (where argon2 is installed):
#   node -e "require('@node-rs/argon2').hash('YOURPASS').then(console.log)"
# OR set SEED_DEMO=1 to use a baked demo hash (password "TestPass123!") for local preview.
SEED_OWNER_PASSWORD_HASH=
SEED_DEMO=

# ---- Currency rates cron ----
# Providers are free and need no key: open.er-api.com (primary, covers RUB) and
# frankfurter.app (ECB fallback). EXCHANGE_API_KEY is unused by them.
EXCHANGE_API_KEY=

# ---- App runtime ----
PORT=3000
NODE_ENV=production
# block until reverse proxy sets it
TRUSTED_HEADER_X_FORWARDED_PROTO=true

# ---- Cron (host scheduler calls these with x-cron-secret header) ----
# generate: openssl rand -hex 32
CRON_SECRET=change-me-cron-secret